# ── Google Sheets API (via Apps Script Web App) ───────────────────────────────
# 1. Go to script.google.com and paste the contents of google-apps-script.js
# 2. Click Deploy → New Deployment → Web App
# 3. Set "Execute as" = Me, "Who has access" = Anyone
# 4. Copy the Web App URL and paste it below
# 5. Rename this file to .env.local

NEXT_PUBLIC_SHEET_API_URL=https://script.google.com/macros/s/AKfycbw6K6u6IqU9oX4T-Ggo7WgxtvOZdZaz7Jr8JFWc7B7hyv-LTIPVHSYljlMEgo-Y3q62/exec
